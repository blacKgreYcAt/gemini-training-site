@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --primary: #00aeef;
    --primary-light: #66d9ff;
    --primary-dark: #0088bb;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    @apply font-sans antialiased bg-white;
  }

  * {
    @apply border-border;
  }
}

@layer components {
  /* Claymorphism Card */
  .clay-card {
    @apply rounded-[20px] bg-white shadow-[0_4px_6px_rgba(0,174,239,0.1),0_10px_20px_rgba(0,0,0,0.08)];
    @apply hover:shadow-[0_8px_12px_rgba(0,174,239,0.15),0_20px_40px_rgba(0,0,0,0.1)];
    @apply transition-all duration-300 hover:-translate-y-1;
  }

  /* Claymorphism Button Primary */
  .clay-btn {
    @apply rounded-[20px] px-6 py-3 bg-[#00aeef] text-white font-semibold;
    @apply shadow-[0_4px_6px_rgba(0,174,239,0.1),0_10px_20px_rgba(0,0,0,0.08)];
    @apply hover:bg-[#0088bb] hover:shadow-[0_8px_12px_rgba(0,174,239,0.15),0_20px_40px_rgba(0,0,0,0.1)];
    @apply transition-all duration-300 hover:-translate-y-1;
  }

  /* Claymorphism Button Outline */
  .clay-btn-outline {
    @apply rounded-[20px] px-6 py-3 border-2 border-[#00aeef] text-[#00aeef] font-semibold;
    @apply hover:bg-[#00aeef]/5 transition-all duration-300;
  }

  /* Claymorphism Input */
  .clay-input {
    @apply rounded-[20px] px-4 py-3 border-2 border-gray-200 focus:border-[#00aeef] focus:outline-none;
    @apply transition-all duration-300;
    @apply shadow-[0_2px_4px_rgba(0,174,239,0.08),0_6px_12px_rgba(0,0,0,0.06)];
  }
}
